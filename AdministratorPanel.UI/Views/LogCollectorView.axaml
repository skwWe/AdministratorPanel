<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AdministratorPanel.UI.ViewModels.LogCollector"
             x:Class="AdministratorPanel.UI.Views.LogCollector.LogCollectorView"
             x:DataType="vm:LogCollectorViewModel"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="TextBox.output">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style Selector="TextBox.input">
            <Setter Property="MinWidth" Value="240"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid ColumnDefinitions="320,*">

            <!-- Левая панель -->
            <Border Grid.Column="0"
                    Classes="card"
                    Margin="0,0,20,0">

                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="Группы серверов"/>

                    <ListBox ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ServerGroupItemViewModel">
                                <Border Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Правая часть -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="16">

                    <!-- SSH -->
                    <Border Classes="card">
                        <StackPanel Spacing="10">

                            <TextBlock Classes="h1" Text="SSH"/>

                            <TextBox Classes="input"
                                     Text="{Binding SshUserName}"
                                     Watermark="Пользователь"/>

                            <TextBox Classes="input"
                                     Text="{Binding Password}"
                                     PasswordChar="*"
                                     Watermark="Пароль"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="secondary"
                                        Content="Проверить SSH"
                                        Command="{Binding TestSshConnectionCommand}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding StatusMessage}"/>

                        </StackPanel>
                    </Border>
					<Border Classes="card">
						<StackPanel Spacing="10">

							<TextBlock Classes="h1" Text="Сбор логов"/>

							<Button Classes="primary"
									Content="Запустить сбор логов"
									Command="{Binding RunCollectionCommand}"
									IsEnabled="{Binding CanRun}"/>

						</StackPanel>
					</Border>
                    <!-- Серверы -->
                    <Border Classes="card">
                        <StackPanel Spacing="10">

                            <TextBlock Classes="h1" Text="Серверы"/>

                            <ListBox ItemsSource="{Binding Servers}"
                                     SelectedItem="{Binding SelectedServer}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RemoteServerItemViewModel">
                                        <Border Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding IpAddress}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Форма -->
                            <TextBox Classes="input"
                                     Text="{Binding ServerDisplayName}"
                                     Watermark="Имя"/>

                            <TextBox Classes="input"
                                     Text="{Binding ServerIpAddress}"
                                     Watermark="IP"/>

                            <CheckBox Content="Активен"
                                      IsChecked="{Binding ServerIsEnabled}"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="primary"
                                        Content="Добавить"
                                        Command="{Binding AddServerCommand}"/>

                                <Button Classes="secondary"
                                        Content="Сохранить"
                                        Command="{Binding UpdateServerCommand}"/>

                                <Button Classes="danger"
                                        Content="Удалить"
                                        Command="{Binding DeleteServerCommand}"/>
								<Button Classes="secondary"
                                        Content="Найти серверы"
                                        Command="{Binding DiscoverServersCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Вывод -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Output"/>
                            <TextBox Classes="output"
                                     Text="{Binding ExecutionOutput}"
                                     Height="150"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="Error"/>
                            <TextBox Classes="output"
                                     Text="{Binding ExecutionError}"
                                     Height="120"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>