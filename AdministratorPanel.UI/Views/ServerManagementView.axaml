<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AdministratorPanel.UI.ViewModels.ServerManagement"
             x:Class="AdministratorPanel.UI.Views.ServerManagement.ServerManagementView"
             x:DataType="vm:ServerManagementViewModel">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style Selector="TextBox.output">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="16">

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="Управление серверами"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"/>

                    <TextBox Text="{Binding ServerName}"
                             Watermark="Имя сервера, например nn-lsed-web01"/>

                    <TextBox Text="{Binding IpAddress}"
                             Watermark="IP-адрес сервера"/>

                    <TextBox Text="{Binding SshUserName}"
                             Watermark="SSH пользователь"/>

                    <TextBox Text="{Binding Password}"
                             PasswordChar="*"
                             Watermark="Пароль"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="Операции"/>

                    <WrapPanel>
                        <Button Content="Диагностика"
                                Margin="0,0,10,10"/>

                        <Button Content="Остановить контейнеры"
                                Margin="0,0,10,10"/>

                        <Button Content="Перезапустить контейнеры"
                                Margin="0,0,10,10"/>

                        <Button Content="Перезапустить Docker"
                                Margin="0,0,10,10"/>

                        <Button Content="Безопасное отключение"
                                Background="#DC2626"
                                Foreground="White"
                                Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="h1" Text="Вывод операции"/>
                    <TextBox Classes="output"
                             Text="{Binding OperationOutput}"
                             MinHeight="220"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="h1" Text="Ошибки"/>
                    <TextBox Classes="output"
                             Text="{Binding OperationError}"
                             MinHeight="160"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>