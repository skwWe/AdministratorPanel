<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AdministratorPanel.UI.ViewModels.ServerManagement"
             x:Class="AdministratorPanel.UI.Views.ServerManagement.ServerManagementView"
             x:DataType="vm:ServerManagementViewModel">
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Background" Value="#F5F7FB"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.input">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="TextBox.output">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EFF6FF"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#DBEAFE"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#6B7280"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="16">
            <!-- Заголовок модуля -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="Управление серверами"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
                    <TextBlock Text="Используется активная SSH-сессия."
                               Foreground="#6B7280" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- План отключения -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="План отключения"/>
                    <TextBlock Text="{Binding LoadedPlanName}" Foreground="#374151" TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*,12,120">
                        <TextBox Grid.Column="0" Text="{Binding ShutdownPlanFilePath}"
                                 Watermark="Путь к Excel-файлу плана отключения" Classes="input"/>
                        <Button Grid.Column="2" Content="Обзор..."
                                Command="{Binding BrowseShutdownPlanFileCommand}"
                                Classes="secondary" HorizontalContentAlignment="Center"/>
                    </Grid>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Classes="primary" Content="Загрузить план"
                                Command="{Binding LoadShutdownPlanCommand}" Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Группы и серверы плана -->
            <Border Classes="card">
                <Grid ColumnDefinitions="280,16,*">
                    <StackPanel Grid.Column="0" Spacing="10">
                        <TextBlock Classes="h2" Text="Группы плана"/>
                        <ListBox ItemsSource="{Binding ShutdownGroups}"
                                 SelectedItem="{Binding SelectedShutdownGroup}" Height="260"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="10">
                        <TextBlock Classes="h2" Text="Серверы выбранной группы"/>
                        <ListBox ItemsSource="{Binding ShutdownServers}"
                                 SelectedItem="{Binding SelectedShutdownServer}" Height="260"/>
                        <Button Content="Использовать сервер"
                                Command="{Binding UseSelectedPlanServerCommand}"
                                Classes="secondary" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Выбранный сервер для операции -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="h1" Text="Выбранный сервер для операции"/>
                    <Grid ColumnDefinitions="*,12,*">
                        <TextBox Grid.Column="0" Text="{Binding ServerName}"
                                 Watermark="Имя сервера" Classes="input"/>
                        <TextBox Grid.Column="2" Text="{Binding IpAddress}"
                                 Watermark="IP-адрес" Classes="input"/>
                    </Grid>
                    <TextBlock Text="Безопасное отключение остановит Docker Compose-сервисы и выполнит shutdown now. Для групп dev и intgr остановка Docker Compose пропускается."
                               Foreground="#6B7280" TextWrapping="Wrap"/>
                    <WrapPanel>
                        <Button Content="Перезапустить сервисы" Command="{Binding RestartServicesCommand}"
                                Classes="secondary" Margin="0,0,10,10"/>
                        <Button Content="Безопасно отключить" Command="{Binding SafeShutdownSelectedServerCommand}"
                                Classes="danger" Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Вывод операции -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="h1" Text="Вывод операции"/>
                    <TextBox Classes="output" Text="{Binding OperationOutput}" MinHeight="180"/>
                </StackPanel>
            </Border>

            <!-- Ошибки -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="h1" Text="Ошибки"/>
                    <TextBox Classes="output" Text="{Binding OperationError}" MinHeight="140"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>