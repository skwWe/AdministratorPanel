<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AdministratorPanel.UI.ViewModels.LogDiagnostics"
             x:Class="AdministratorPanel.UI.Views.LogDiagnostics.LogDiagnosticsView"
             x:DataType="vm:LogDiagnosticsViewModel">

    <Grid ColumnDefinitions="1*, 2*" Margin="20" RowDefinitions="Auto,*">
        <!-- Левая панель: список сессий -->
        <Border Grid.Row="1" Grid.Column="0" Classes="card" Margin="0,10,10,0">
            <StackPanel Spacing="10">
                <TextBlock Classes="h1" Text="Сессии сбора"/>
                <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         MaxHeight="400">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" CornerRadius="8" Margin="0,2">
                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="Обновить" Command="{Binding LoadSessionsCommand}" Classes="secondary"/>
            </StackPanel>
        </Border>

        <!-- Правая панель: анализ -->
        <Border Grid.Row="1" Grid.Column="1" Classes="card" Margin="10,10,0,0">
            <StackPanel Spacing="12">
                <TextBlock Classes="h1" Text="Анализ логов"/>
                <TextBlock Text="Регулярное выражение для поиска" Classes="h2"/>
                <TextBox Text="{Binding SearchPattern}" Classes="input"/>
                <Button Content="Запустить анализ" Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding !IsAnalyzing}" Classes="primary"/>
                <TextBlock Classes="h2" Text="Результат"/>
                <TextBox Text="{Binding AnalysisResult}" Classes="output"
                         MinHeight="300" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>